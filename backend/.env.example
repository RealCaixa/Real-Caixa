NODE_ENV=development
PORT=3000

# Defina um segredo forte em staging/producao.
# Em producao, o servidor falha ao iniciar sem JWT_SECRET.
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_EXPIRES_IN=8h

# Dominios autorizados para homologacao. Separe multiplos por virgula.
# Exemplo: https://realcaixa-homologacao.vercel.app,https://preview-realcaixa.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
HOMOLOGACAO_URL=https://realcaixa-homologacao.vercel.app

# Banco de dados
# sqljs: desenvolvimento local atual
# postgres: homologacao/producao com Supabase, Neon, Railway ou PostgreSQL gerenciado
DATABASE_PROVIDER=sqljs
DATABASE_URL=
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MAX=5
DATABASE_IDLE_TIMEOUT_MS=30000

# Opcional em desenvolvimento/testes locais.
# ATENCAO: sql.js/realcaixa.db nao e persistente de forma confiavel em Vercel/serverless.
# Para homologacao com escrita real, migrar para PostgreSQL/Supabase/Neon antes do piloto externo.
REALCAIXA_DB_PATH=./realcaixa.db
LOG_LEVEL=debug
